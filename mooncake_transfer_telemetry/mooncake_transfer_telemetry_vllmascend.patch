     def get(self, keys: list[str], addrs: list[list[int]], sizes: list[list[int]]):
+        attempted_bytes = sum(sum(s) for s in sizes)
+        num_keys = len(keys)
+        num_descriptors = sum(len(s) for s in sizes)
+
+        # Path-infer network_type from registered buffer regions.
+        net_type, net_source = classify_network_type(
+            component="store",
+            local_regions=self._local_buffer_regions,
+        )
+
+        start_ns = time.perf_counter_ns()
+        error_kind = "none"
+        outcome = "success"
+        completed_bytes = 0
         try:
             res = self.store.batch_get_into_multi_buffers(keys, addrs, sizes)
+            success_count = 0
+            fail_count = 0
+            for value in res:
+                if value >= 0:
+                    success_count += 1
+                    completed_bytes += value
+                else:
+                    fail_count += 1
+            # Guard against empty result vector (e.g. dummy client).
+            if success_count == 0 and fail_count == 0:
+                outcome = "error"
+                error_kind = "invalid_result"
+                completed_bytes = 0
+            elif fail_count == 0:
+                outcome = "success"
+            elif success_count == 0:
+                outcome = "error"
+                error_kind = "return_code"
+                completed_bytes = 0
+            else:
+                outcome = "partial"
+                error_kind = "return_code"
             for value in res:
                 if value < 0:
                     logger.error(f"Failed to get key {keys}, res:{res}")
         except Exception as e:
+            outcome = "error"
+            error_kind = "exception"
             logger.error(f"Failed to get key {keys}, error:{e}")
+        finally:
+            duration_ns = time.perf_counter_ns() - start_ns
+            duration_s = duration_ns / 1e9
+
+            record_mooncake_io(
+                self._io_collector,
+                component="store",
+                operation="get",
+                outcome=outcome,
+                error_kind=error_kind,
+                attempted_bytes=attempted_bytes,
+                completed_bytes=completed_bytes if outcome != "error" else None,
+                operations=num_keys,
+                descriptors=num_descriptors,
+                duration_seconds=duration_s,
+                network_type=net_type,
+                network_type_source=net_source,
+            )
+            log_mooncake_io_event(
+                "store_get_end",
+                component="store",
+                operation="get",
+                outcome=outcome,
+                network_type=net_type,
+                network_type_source=net_source,
+                attempted_bytes=attempted_bytes,
+                completed_bytes=completed_bytes if outcome != "error" else None,
+                operations=num_keys,
+                descriptors=num_descriptors,
+                duration_ns=duration_ns,
+                extra={"num_keys": num_keys},
+            )
+
+    def get_kv_connector_stats(self) -> "KVConnectorStats | None":
+        """Drain Store IO stats."""
+        return self._io_collector.drain()
 
 
