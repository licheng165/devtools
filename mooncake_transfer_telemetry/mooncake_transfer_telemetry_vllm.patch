+class TestThreadSafety:
+    """Tests for concurrent record/drain."""
+
+    def test_concurrent_record_drain(self):
+        collector = MooncakeIOStatsCollector()
+        stop = threading.Event()
+        record_count = [0]
+        record_lock = threading.Lock()
+
+        def recorder():
+            while not stop.is_set():
+                record_mooncake_io(
+                    collector,
+                    component="p2p",
+                    operation="read",
+                    outcome="success",
+                    error_kind="none",
+                    attempted_bytes=100,
+                    completed_bytes=100,
+                    operations=1,
+                    descriptors=1,
+                    duration_seconds=0.0001,
+                    network_type="npu_side",
+                    network_type_source="path_inference",
+                )
+                with record_lock:
+                    record_count[0] += 1
+
+        threads = [threading.Thread(target=recorder, daemon=True) for _ in range(4)]
+        for t in threads:
+            t.start()
+
+        total_drained_calls = 0
+        for _ in range(10):
+            drained = collector.drain()
+            if drained is not None:
+                for t in drained.data.get("totals", {}).values():
+                    total_drained_calls += t["calls"]
+            threading.Event().wait(0.001)
+
+        stop.set()
+        for t in threads:
+            t.join(timeout=1)
+
+        # All recorded events should be either in the collector or drained.
+        # No events lost or double counted.
+        final_drain = collector.drain()
+        final_calls = 0
+        if final_drain is not None:
+            for t in final_drain.data.get("totals", {}).values():
+                final_calls += t["calls"]
+
+        assert total_drained_calls + final_calls == record_count[0]
+
+
+class TestSerialization:
+    """Tests for dataclass serialization (cross-process)."""
+
+    def test_stats_is_plain_dict(self):
+        collector = MooncakeIOStatsCollector()
+        record_mooncake_io(
+            collector,
+            component="p2p",
+            operation="read",
+            outcome="success",
+            error_kind="none",
+            attempted_bytes=42,
+            completed_bytes=42,
+            operations=1,
+            descriptors=1,
+            duration_seconds=0.001,
+            network_type="npu_side",
+            network_type_source="path_inference",
+            transfer_id="t1",
+        )
+        drained = collector.drain()
+        # data must be serializable as plain dict for cross-process.
+        data: dict[str, Any] = drained.data
+        assert isinstance(data, dict)
+        assert isinstance(data["totals"], dict)
+        assert isinstance(data["durations"], dict)
+        assert isinstance(data["logical_transfer_ids"], list)
+
+        # Reconstruct from serialized data.
+        rebuilt = MooncakeIOStats(data=data)
+        assert not rebuilt.is_empty()
+        totals = rebuilt.data["totals"]
+        key = list(totals.keys())[0]
+        assert totals[key]["calls"] == 1
+        assert "t1" in rebuilt.data["logical_transfer_ids"]
