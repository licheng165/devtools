+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Unit tests for mooncake_metrics telemetry module."""
+
+import threading
+from typing import Any
+
+import pytest
+
+from vllm.distributed.kv_transfer.kv_connector.v1.mooncake.mooncake_metrics import (
+    KVBufferRegion,
+    MooncakeIOObservation,
+    MooncakeIOStats,
+    MooncakeIOStatsCollector,
+    classify_network_type,
+    record_mooncake_io,
+)
+
+
+class TestClassifyNetworkType:
+    """Tests for the path-inference network-type classifier."""
+
+    def test_no_submission_returns_none(self):
+        net, src = classify_network_type(
+            component="p2p",
+            local_regions=[KVBufferRegion(0, 100, "npu")],
+            remote_regions=[KVBufferRegion(0, 100, "npu")],
+            submitted=False,
+            attempted_bytes=0,
+        )
+        assert net == "none"
+        assert src == "path_inference"
+
+    def test_zero_bytes_returns_none(self):
+        net, src = classify_network_type(
+            component="p2p",
+            local_regions=[KVBufferRegion(0, 100, "npu")],
+            remote_regions=[KVBufferRegion(0, 100, "npu")],
+            submitted=True,
+            attempted_bytes=0,
+        )
+        assert net == "none"
+
+    def test_p2p_npu_both_sides(self):
+        net, src = classify_network_type(
+            component="p2p",
+            local_regions=[KVBufferRegion(0, 100, "npu")],
+            remote_regions=[KVBufferRegion(0, 100, "npu")],
+        )
+        assert net == "npu_side"
+        assert src == "path_inference"
+
+    def test_p2p_host_both_sides(self):
+        net, src = classify_network_type(
+            component="p2p",
+            local_regions=[KVBufferRegion(0, 100, "cpu")],
+            remote_regions=[KVBufferRegion(0, 100, "host")],
+        )
+        assert net == "host_side"
+
+    def test_p2p_mixed_npu_host(self):
+        net, src = classify_network_type(
+            component="p2p",
+            local_regions=[KVBufferRegion(0, 100, "npu")],
+            remote_regions=[KVBufferRegion(0, 100, "cpu")],
+        )
+        assert net == "unknown"
+        assert src == "unresolved"
+
+    def test_p2p_missing_remote(self):
+        net, src = classify_network_type(
+            component="p2p",
+            local_regions=[KVBufferRegion(0, 100, "npu")],
+            remote_regions=None,
+        )
+        assert net == "unknown"
+
+    def test_store_npu(self):
+        net, src = classify_network_type(
+            component="store",
+            local_regions=[KVBufferRegion(0, 100, "npu")],
+        )
+        assert net == "npu_side"
+
+    def test_store_host(self):
+        net, src = classify_network_type(
+            component="store",
+            local_regions=[KVBufferRegion(0, 100, "cpu")],
+        )
+        assert net == "host_side"
+
+    def test_store_empty_regions(self):
+        net, src = classify_network_type(
+            component="store",
+            local_regions=[],
+        )
+        assert net == "unknown"
+
+
+class TestMooncakeIOStats:
+    """Tests for the stats container."""
+
+    def test_empty_stats(self):
+        stats = MooncakeIOStats(data={})
+        assert stats.is_empty()
+
+    def test_record_and_drain(self):
+        collector = MooncakeIOStatsCollector()
+        record_mooncake_io(
+            collector,
+            component="p2p",
+            operation="read",
+            outcome="success",
+            error_kind="none",
+            attempted_bytes=1024,
+            completed_bytes=1024,
+            operations=10,
+            descriptors=10,
+            duration_seconds=0.001,
+            network_type="npu_side",
+            network_type_source="path_inference",
+            transfer_id="t1",
+        )
+        drained = collector.drain()
+        assert drained is not None
+        assert not drained.is_empty()
+        totals = drained.data["totals"]
+        assert len(totals) == 1
+        key = list(totals.keys())[0]
+        assert totals[key]["calls"] == 1
+        assert totals[key]["attempted_bytes"] == 1024
+        assert totals[key]["completed_bytes"] == 1024
+        assert "t1" in drained.data["logical_transfer_ids"]
+
+    def test_drain_clears(self):
+        collector = MooncakeIOStatsCollector()
+        record_mooncake_io(
+            collector,
+            component="p2p",
+            operation="read",
+            outcome="success",
+            error_kind="none",
+            attempted_bytes=100,
+            completed_bytes=100,
+            operations=1,
+            descriptors=1,
+            duration_seconds=0.01,
+            network_type="npu_side",
+            network_type_source="path_inference",
+        )
+        drained = collector.drain()
+        assert drained is not None
+        # Second drain should be None.
+        drained2 = collector.drain()
+        assert drained2 is None
+
+    def test_aggregate(self):
+        s1 = MooncakeIOStats(data={})
+        s1.record(
+            MooncakeIOObservation(
+                component="p2p",
+                operation="read",
+                outcome="success",
+                error_kind="none",
+                network_type="npu_side",
+                network_type_source="path_inference",
+                attempted_bytes=100,
+                completed_bytes=100,
+                operations=1,
+                descriptors=1,
+                duration_seconds=0.001,
+                transfer_id="t1",
+            )
+        )
+        s2 = MooncakeIOStats(data={})
+        s2.record(
+            MooncakeIOObservation(
+                component="p2p",
+                operation="read",
+                outcome="success",
+                error_kind="none",
+                network_type="npu_side",
+                network_type_source="path_inference",
+                attempted_bytes=200,
+                completed_bytes=200,
+                operations=2,
+                descriptors=2,
+                duration_seconds=0.002,
+                transfer_id="t1",
+            )
+        )
+        s1.aggregate(s2)
+        totals = s1.data["totals"]
+        key = list(totals.keys())[0]
+        assert totals[key]["calls"] == 2
+        assert totals[key]["attempted_bytes"] == 300
+        assert totals[key]["completed_bytes"] == 300
+        # transfer_id dedup
+        assert s1.data["logical_transfer_ids"] == ["t1"]
+
+    def test_failed_no_completed_bytes(self):
+        collector = MooncakeIOStatsCollector()
+        record_mooncake_io(
+            collector,
+            component="p2p",
+            operation="read",
+            outcome="error",
+            error_kind="return_code",
+            attempted_bytes=1024,
+            completed_bytes=None,
+            operations=10,
+            descriptors=10,
+            duration_seconds=0.001,
+            network_type="npu_side",
+            network_type_source="path_inference",
+        )
+        drained = collector.drain()
+        totals = drained.data["totals"]
+        key = list(totals.keys())[0]
+        assert totals[key]["completed_bytes"] == 0
+        assert "error" in key
+
+    def test_reduce(self):
+        collector = MooncakeIOStatsCollector()
+        for i in range(5):
+            record_mooncake_io(
+                collector,
+                component="store",
+                operation="put",
+                outcome="success",
+                error_kind="none",
+                attempted_bytes=100 * (i + 1),
+                completed_bytes=100 * (i + 1),
+                operations=i + 1,
+                descriptors=i + 1,
+                duration_seconds=0.001 * (i + 1),
+                network_type="npu_side",
+                network_type_source="path_inference",
+            )
+        drained = collector.drain()
+        reduced = drained.reduce()
+        assert reduced["store_put_success_npu_side_calls"] == 5
+        assert reduced["store_put_success_npu_side_attempted_bytes"] == 1500
+        assert reduced["store_put_success_npu_side_completed_bytes"] == 1500
+
