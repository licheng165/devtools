+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Reusable Mooncake network-IO telemetry for KV connectors.
+
+This module is device-agnostic (no torch/npu imports) so it can be unit
+tested on CPU-only machines and shared by:
+
+* vLLM-Ascend ``MooncakeConnectorV1`` (P2P direct transfer)
+* vLLM-Ascend ``AscendStoreConnector`` (Mooncake-backed KV pool)
+* upstream vLLM ``MooncakeConnector``
+* LMCache ``MooncakestoreConnector`` (host-side staging path)
+
+Design invariants
+-----------------
+1. Stats are recorded once at the *outermost* semantic Mooncake API call.
+2. The shared ``GlobalTE`` is never instrumented or drained.
+3. P2P transfers are counted only on the side that issues the Mooncake
+   read/write, avoiding P/D double counting.
+4. Store ``put`` and ``get`` are two distinct IO phases and are counted
+   separately.
+5. TP/PP worker aggregation sums payload bytes directly (each rank owns
+   a different KV shard); no ``/TP`` or ``/DP`` division is applied.
+6. ``network_type`` is *path-inferred* from the runtime connector path
+   and registered buffer memory kind -- it is **not** a native report
+   from Mooncake C++.  ``network_type_source`` distinguishes
+   ``path_inference`` from ``unresolved`` so downstream consumers know
+   the confidence level.
+7. Latency uses ``time.perf_counter_ns`` (monotonic).  Cross-node
+   correlation additionally records ``time.time_ns`` (wall clock) in
+   structured logs only.
+8. No additional ``torch.npu.synchronize()`` is introduced.
+"""
+
+from __future__ import annotations
+
+import copy
+import json
+import threading
+import time
+from dataclasses import dataclass
+from typing import Any, Literal
+
+from vllm.distributed.kv_transfer.kv_connector.v1.metrics import KVConnectorStats
+from vllm.logger import init_logger
+
+logger = init_logger(__name__)
+
+# ---------------------------------------------------------------------------
+# Constants
+# ---------------------------------------------------------------------------
+
+NetworkType = Literal["npu_side", "host_side", "none", "unknown"]
+NetworkTypeSource = Literal["path_inference", "unresolved"]
+Component = Literal["p2p", "store"]
+Operation = Literal["read", "write", "get", "put"]
+Outcome = Literal["success", "partial", "error", "skip"]
+ErrorKind = Literal[
+    "none", "return_code", "exception", "invalid_result", "skipped"
+]
+
+# Memory kinds that map to NPU data plane.
+_NPU_MEMORY_KINDS = frozenset({"npu", "ascend"})
+
+
+# ---------------------------------------------------------------------------
+# Data classes
+# ---------------------------------------------------------------------------
+
+
+@dataclass(frozen=True)
+class KVBufferRegion:
+    """A registered KV-cache buffer region.
+
+    ``memory_kind`` is derived from the tensor's ``device.type`` at
+    registration time (e.g. ``"npu"``, ``"cuda"``, ``"cpu"``).  It is a
+    *memory fact*, not a network fact, but it is the strongest signal
+    available without modifying Mooncake C++ bindings.
+    """
+
+    base_address: int
+    length: int
+    memory_kind: str
+    device_index: int | None = None
+
+
+@dataclass(frozen=True)
+class MooncakeIOObservation:
+    """A single Mooncake data-plane API call observation."""
+
+    component: Component
+    operation: Operation
+    outcome: Outcome
+    error_kind: ErrorKind
+    network_type: NetworkType
+    network_type_source: NetworkTypeSource
+    attempted_bytes: int
+    completed_bytes: int | None  # None when partial completion is unobservable
+    operations: int  # logical ops (P2P descriptors, Store keys)
+    descriptors: int  # physical buffer descriptors submitted
+    duration_seconds: float
+    # Optional phase durations (seconds).  Only meaningful for P2P.
+    queue_duration_seconds: float | None = None
+    prepare_duration_seconds: float | None = None
+    postprocess_duration_seconds: float | None = None
+    # Opaque transfer id for in-process dedup only.
+    transfer_id: str | None = None
+
+
+# ---------------------------------------------------------------------------
+# Network-type path inference
+# ---------------------------------------------------------------------------
+
+
+def classify_network_type(
+    component: Component,
+    local_regions: list[KVBufferRegion] | None,
+    remote_regions: list[KVBufferRegion] | None = None,
+    submitted: bool = True,
+    attempted_bytes: int = 0,
+) -> tuple[NetworkType, NetworkTypeSource]:
+    """Path-infer ``network_type`` from runtime facts.
+
+    The classifier never reads IPs, NIC names, environment variables, or
+    the Mooncake config file.  It relies solely on:
+
+    * the connector/backend Python type (``component``)
+    * the registered buffer memory kinds (``local_regions`` /
+      ``remote_regions``)
+
+    Returns ``(network_type, network_type_source)``.
+    """
+    if not submitted or attempted_bytes == 0:
+        return "none", "path_inference"
+
+    local_kinds: set[str] = set()
+    if local_regions:
+        for r in local_regions:
+            local_kinds.add(r.memory_kind)
+    remote_kinds: set[str] = set()
+    if remote_regions:
+        for r in remote_regions:
+            remote_kinds.add(r.memory_kind)
+
+    if component == "store":
+        # Store multi-buffer APIs receive addresses from the caller's
+        # registered KV tensors.  If all local regions are NPU memory,
+        # the payload is inferred to travel on the NPU side.
+        if local_kinds and local_kinds <= _NPU_MEMORY_KINDS:
+            return "npu_side", "path_inference"
+        if local_kinds and local_kinds <= {"cpu", "host"}:
+            return "host_side", "path_inference"
+        return "unknown", "unresolved"
+
+    # P2P direct transfer: both sides must be resolved.
+    if not local_kinds or not remote_kinds:
+        return "unknown", "unresolved"
+
+    if local_kinds <= _NPU_MEMORY_KINDS and remote_kinds <= _NPU_MEMORY_KINDS:
+        return "npu_side", "path_inference"
+    if local_kinds <= {"cpu", "host"} and remote_kinds <= {"cpu", "host"}:
+        return "host_side", "path_inference"
+    # Mixed or non-NPU/non-host device.
+    return "unknown", "unresolved"
+
+
+# ---------------------------------------------------------------------------
+# Stats container
+# ---------------------------------------------------------------------------
+
+
+@dataclass
+class MooncakeIOStats(KVConnectorStats):
+    """Serializable container for Mooncake IO observations.
+
+    ``data`` has the shape::
+
+        {
+            "schema_version": 1,
+            "totals": {
+                "<component>|<operation>|<outcome>|<network_type>|"
+                "<network_type_source>|<error_kind>": {
+                    "calls": int,
+                    "attempted_bytes": int,
+                    "completed_bytes": int,   # 0 if unobservable
+                    "operations": int,
+                    "descriptors": int,
+                },
+                ...
+            },
+            "durations": {
+                "<same key>": [float, ...],
+            },
+            "logical_transfer_ids": [str, ...],
+        }
+    """
+
+    def __post_init__(self):
+        if not self.data:
+            self.reset()
+
+    def reset(self):
+        self.data: dict[str, Any] = {
+            "schema_version": 1,
+            "totals": {},
+            "durations": {},
+            "logical_transfer_ids": [],
+        }
+
+    @staticmethod
+    def _key(obs: MooncakeIOObservation) -> str:
+        return "|".join([
+            obs.component,
+            obs.operation,
+            obs.outcome,
+            obs.network_type,
+            obs.network_type_source,
+            obs.error_kind,
+        ])
+
+    def record(self, obs: MooncakeIOObservation) -> None:
+        key = self._key(obs)
+        totals = self.data["totals"]
+        if key not in totals:
+            totals[key] = {
+                "calls": 0,
+                "attempted_bytes": 0,
+                "completed_bytes": 0,
+                "operations": 0,
+                "descriptors": 0,
+            }
+        t = totals[key]
+        t["calls"] += 1
+        t["attempted_bytes"] += obs.attempted_bytes
+        if obs.completed_bytes is not None:
+            t["completed_bytes"] += obs.completed_bytes
+        t["operations"] += obs.operations
+        t["descriptors"] += obs.descriptors
+
+        durations = self.data["durations"]
+        if key not in durations:
+            durations[key] = []
+        durations[key].append(obs.duration_seconds)
+
+        if obs.transfer_id is not None:
+            ids = self.data["logical_transfer_ids"]
+            if obs.transfer_id not in ids:
+                ids.append(obs.transfer_id)
+
+    def aggregate(self, other: KVConnectorStats) -> KVConnectorStats:
+        if not isinstance(other, MooncakeIOStats):
+            return self
+        if other.is_empty():
+            return self
+
+        for key, other_t in other.data.get("totals", {}).items():
+            my_t = self.data["totals"].setdefault(key, {
+                "calls": 0,
+                "attempted_bytes": 0,
+                "completed_bytes": 0,
+                "operations": 0,
+                "descriptors": 0,
+            })
+            my_t["calls"] += other_t["calls"]
+            my_t["attempted_bytes"] += other_t["attempted_bytes"]
+            my_t["completed_bytes"] += other_t["completed_bytes"]
+            my_t["operations"] += other_t["operations"]
+            my_t["descriptors"] += other_t["descriptors"]
+
+        for key, other_durs in other.data.get("durations", {}).items():
+            self.data["durations"].setdefault(key, []).extend(other_durs)
+
+        existing_ids = set(self.data.get("logical_transfer_ids", []))
+        for tid in other.data.get("logical_transfer_ids", []):
+            if tid not in existing_ids:
+                self.data["logical_transfer_ids"].append(tid)
+                existing_ids.add(tid)
+
+        return self
+
+    def reduce(self) -> dict[str, int | float]:
+        result: dict[str, int | float] = {}
+        for key, t in self.data.get("totals", {}).items():
+            parts = key.split("|")
+            prefix = f"{parts[0]}_{parts[1]}_{parts[2]}_{parts[3]}"
+            result[f"{prefix}_calls"] = t["calls"]
+            result[f"{prefix}_attempted_bytes"] = t["attempted_bytes"]
+            result[f"{prefix}_completed_bytes"] = t["completed_bytes"]
+            result[f"{prefix}_operations"] = t["operations"]
+            result[f"{prefix}_descriptors"] = t["descriptors"]
+        for key, durs in self.data.get("durations", {}).items():
+            parts = key.split("|")
+            prefix = f"{parts[0]}_{parts[1]}_{parts[2]}_{parts[3]}"
+            if durs:
+                avg = sum(durs) / len(durs)
+                sorted_durs = sorted(durs)
+                p99_idx = min(int(len(sorted_durs) * 0.99), len(sorted_durs) - 1)
+                result[f"{prefix}_avg_duration_ms"] = round(avg * 1e3, 3)
+                result[f"{prefix}_p99_duration_ms"] = round(
+                    sorted_durs[p99_idx] * 1e3, 3
+                )
+        result["logical_transfers"] = len(
+            self.data.get("logical_transfer_ids", [])
+        )
+        return result
+
+    def is_empty(self) -> bool:
+        return not self.data.get("totals") and not self.data.get(
+            "durations"
+        )
+
+    def clone_and_reset(self) -> MooncakeIOStats:
+        old = copy.copy(self)
+        old.data = copy.deepcopy(self.data)
+        self.reset()
+        return old
+
+
+# ---------------------------------------------------------------------------
+# Thread-safe collector
+# ---------------------------------------------------------------------------
+
+
+class MooncakeIOStatsCollector:
+    """Thread-safe accumulator for :class:`MooncakeIOObservation`.
+
+    Multiple background transfer threads may call :meth:`record`
+    concurrently while the model-runner thread calls :meth:`drain` once
+    per engine step.  Drain atomically swaps internal containers so no
+    observations are lost or double-counted.
+    """
+
+    def __init__(self):
+        self._lock = threading.Lock()
+        self._stats = MooncakeIOStats(data={})
+
+    def record(self, obs: MooncakeIOObservation) -> None:
+        with self._lock:
+            self._stats.record(obs)
+
+    def drain(self) -> MooncakeIOStats | None:
